@model FlipTracks.Models.Item

<h1>Mark Item as Sold</h1>

<p>@Model.Name</p>

<form method="post">
    <input type="hidden" name="Id" value="@Model.Id" />

    <label>Sale Source:</label>
    <select id="saleSourceSelect" name="SaleSource">
        <option value="">-- Select Source --</option>
        <option value="FB Marketplace">FB Marketplace</option>
        <option value="Craigslist">Craigslist</option>
        <option value="eBay">eBay</option>
        <option value="Mercari">Mercari</option>
        <option value="Garage Sale">Garage Sale</option>
        <option value="Other">Other</option>
    </select>

    <input type="text"
           id="otherSaleSourceInput"
           name="OtherSaleSource"
           placeholder="Enter other sale source"
           style="display:none;" />

    <label>Sale Price:</label>
    <input type="number" step="0.01" name="SalePrice" value="@Model.SalePrice" />
    <label>Sale Date:</label>
    <input type="date" name="SaleDate" value="@(Model.SaleDate?.ToString("yyyy-MM-dd") ?? "")" />
    <button type="submit">Save</button>
</form>

<script>
    const saleSelect = document.getElementById("saleSourceSelect");
    const otherSaleInput = document.getElementById("otherSaleSourceInput");

    saleSelect.addEventListener("change", function () {
        if (saleSelect.value === "Other") {
            otherSaleInput.style.display = "block";
        } else {
            otherSaleInput.style.display = "none";
            otherSaleInput.value = "";
        }
    });
</script>